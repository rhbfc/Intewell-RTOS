menu "Irqchip Select"
    
config GIC_VERSION_V3
    bool "ARM GIC-V3 driver"
    default y
    depends on ARM_64 || ARM_32
    help
      This selects the ARM gic-v3 driver.

config GIC_VERSION_V2
    bool "ARM GIC-V2 driver"
    default n
    depends on ARM_64 || ARM_32
    help
      This selects the ARM gic-v2 driver.

endmenu
