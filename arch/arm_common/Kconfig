config SMP
	bool "smp"
	default y
	
config MAX_CPUS
	int "support cpu max numbers"
	default 8
	depends on SMP
	---help---
		config support cpu numbers

config CPU_USAGE_MONITOR
	bool "cpu usage monitor"
	default y
	---help---
		config cpu usage monitor

config IPI_TEST_HWIRQ
	int "ipi test hwirq"
	default 4
	---help---
		config ipi test hwirq