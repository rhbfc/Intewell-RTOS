menu "Log"

config KLOG_BUFF_SIZE
    hex "circle buffer size for klog"
    default 0x1000000

choice
    prompt "Log level"
    default LOG_LEVEL_EMERG

    config LOG_LEVEL_DEBUG
        bool "Debug"

    config LOG_LEVEL_INFO
        bool "Info"

    config LOG_LEVEL_WARN
        bool "Warning"

    config LOG_LEVEL_ERROR
        bool "Error"

    config LOG_LEVEL_EMERG
        bool "Emerg"

endchoice

endmenu
