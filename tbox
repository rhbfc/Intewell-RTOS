import shutil
import subprocess
import sys
import json
import os
import shlex
import tempfile
import urllib.request
import time
from pathlib import Path

SCHEMA = "build-env/yaml/preset.schema.yaml"
BOARD_DIR       = Path("boards-iprj")
BOARD_EXT_DIR   = Path("boards-prj")

GEN_PRESETS = "build-env/tools/gen_presets.py"
EXT_SCRIPT = "build-env/tools/upboard_ext.py"
KCFG_AUTO = "build-env/tools/kconfig_auto.py"
VSCODE_TEMPLATE_DIR = Path("build-env/tools/vscode")
VSCODE_TARGET_DIR = Path(".vscode")
COMPLETION_SCRIPT = Path("build-env/tools/completion/tbox.bash")
CI_BOARDS_CONFIG = Path("ci_boards.json")

def eprint(msg: str):
    print(msg, file=sys.stderr)


def format_bytes(num: float):
    units = ["B", "KB", "MB", "GB", "TB"]
    value = float(num)
    for unit in units:
        if value < 1024.0 or unit == units[-1]:
            return f"{value:.1f}{unit}"
        value /= 1024.0


def progress_bar(ratio: float, width: int = 28):
    ratio = max(0.0, min(1.0, ratio))
    filled = int(ratio * width)
    return "[" + "#" * filled + "-" * (width - filled) + "]"


def can_render_single_line_progress():
    if not sys.stderr.isatty():
        return False
    term = os.environ.get("TERM", "").strip().lower()
    if term in ("", "dumb"):
        return False
    if os.environ.get("TBOX_PROGRESS_PLAIN", "").strip() in ("1", "true", "yes", "on"):
        return False
    return True

def find_ext_board_dirs():
    """
    扫描 BOARD_EXT_DIR/prj/boards
    返回 List[str]
    """
    dirs = []

    if not BOARD_EXT_DIR.is_dir():
        return dirs

    for pkg in sorted(BOARD_EXT_DIR.iterdir()):
        if not pkg.is_dir():
            continue

        board_dir = pkg / "yaml"
        if not board_dir.is_dir():
            continue

        dirs.append(str(board_dir))

    return dirs


def run(cmd):
    subprocess.run(cmd, check=True)


def usage():
    print(
        "Usage:\n"
        "  tbox                     # normal mode\n"
        "  tbox vscode              # copy vscode templates\n"
        "  tbox completion          # print bash completion script\n"
        "  tbox toolchain --list [--config <my_ci_boards.json>]\n"
        "  tbox toolchain <name> [--config <my_ci_boards.json>]\n"
        "  tbox --ext [args]        # ext mode (must be first argument)\n"
    )


def load_toolchains(config_path: Path):
    if not config_path.is_file():
        raise FileNotFoundError(f"toolchains config not found: {config_path}")

    with config_path.open("r", encoding="utf-8") as f:
        data = json.load(f)

    toolchains = data.get("toolchains")
    if not isinstance(toolchains, dict):
        raise ValueError(f"invalid config '{config_path}': 'toolchains' must be an object")
    return toolchains


def parse_toolchains_args(args):
    config = CI_BOARDS_CONFIG
    list_only = False
    name = None
    i = 0

    while i < len(args):
        a = args[i]
        if a in ("-h", "--help", "?"):
            return {"help": True}
        if a == "--list":
            list_only = True
            i += 1
            continue
        if a == "--config":
            i += 1
            if i >= len(args):
                raise ValueError("--config requires a path")
            config = Path(args[i])
            i += 1
            continue
        if a.startswith("--config="):
            config = Path(a.split("=", 1)[1])
            i += 1
            continue
        if a.startswith("-"):
            raise ValueError(f"unknown option: {a}")
        if name is not None:
            raise ValueError(f"unexpected extra argument: {a}")
        name = a
        i += 1

    if not list_only and not name:
        raise ValueError("missing toolchain name")

    return {
        "help": False,
        "list_only": list_only,
        "name": name,
        "config": config,
    }


def is_writable_or_creatable_dir(path: Path):
    if path.is_dir():
        return os.access(path, os.W_OK)
    parent = path.parent
    return parent.is_dir() and os.access(parent, os.W_OK)


def ensure_dir(path: Path):
    path.mkdir(parents=True, exist_ok=True)


def run_sudo(cmd):
    subprocess.run(["sudo", *cmd], check=True)


def download_file(url: str, dst: Path):
    with urllib.request.urlopen(url) as response, dst.open("wb") as f:
        total = response.headers.get("Content-Length")
        total_size = int(total) if total and total.isdigit() else 0
        downloaded = 0
        last_ts = time.monotonic()
        last_bytes = 0
        chunk_size = 1024 * 1024
        use_single_line = can_render_single_line_progress()
        refresh_interval = 0.2 if use_single_line else 1.0

        if total_size > 0:
            eprint(f"[toolchain] archive size: {format_bytes(total_size)}")

        while True:
            chunk = response.read(chunk_size)
            if not chunk:
                break
            f.write(chunk)
            downloaded += len(chunk)

            now = time.monotonic()
            if now - last_ts >= refresh_interval:
                delta_t = now - last_ts
                speed = (downloaded - last_bytes) / delta_t if delta_t > 0 else 0
                if total_size > 0:
                    percent = downloaded * 100.0 / total_size
                    if use_single_line:
                        line = (
                            f"[toolchain] {progress_bar(downloaded / total_size)} "
                            f"{percent:5.1f}% "
                            f"{format_bytes(downloaded)}/{format_bytes(total_size)} "
                            f"{format_bytes(speed)}/s"
                        )
                        sys.stderr.write(f"\r\033[2K{line}")
                        sys.stderr.flush()
                    else:
                        eprint(
                            f"[toolchain] progress: {percent:5.1f}% "
                            f"({format_bytes(downloaded)}/{format_bytes(total_size)}) "
                            f"speed={format_bytes(speed)}/s"
                        )
                else:
                    if use_single_line:
                        line = (
                            f"[toolchain] {progress_bar(0.0)}  ???.?% "
                            f"{format_bytes(downloaded)} "
                            f"{format_bytes(speed)}/s"
                        )
                        sys.stderr.write(f"\r\033[2K{line}")
                        sys.stderr.flush()
                    else:
                        eprint(
                            f"[toolchain] downloaded: {format_bytes(downloaded)} "
                            f"speed={format_bytes(speed)}/s"
                        )
                last_ts = now
                last_bytes = downloaded

        if use_single_line:
            sys.stderr.write("\n")
            sys.stderr.flush()

        if total_size > 0:
            eprint(
                f"[toolchain] download completed: "
                f"{format_bytes(downloaded)}/{format_bytes(total_size)}"
            )
        else:
            eprint(f"[toolchain] download completed: {format_bytes(downloaded)}")


def ensure_toolchain_installed(tc_name: str, tc: dict):
    url = str(tc.get("url", "")).strip()
    extract_to = Path(str(tc.get("extract_to", "/opt")).strip() or "/opt")
    bin_path = Path(str(tc.get("bin_path", "")).strip())

    if not url:
        raise ValueError(f"toolchain '{tc_name}' missing 'url'")
    if not str(bin_path):
        raise ValueError(f"toolchain '{tc_name}' missing 'bin_path'")

    if bin_path.is_dir():
        eprint(f"[toolchain] found existing path: {bin_path}")
        return bin_path

    eprint(f"[toolchain] downloading '{tc_name}' from: {url}")
    with tempfile.NamedTemporaryFile(prefix=f"{tc_name}-", suffix=".tgz", delete=False) as tmp:
        tmp_path = Path(tmp.name)

    try:
        download_file(url, tmp_path)

        if is_writable_or_creatable_dir(extract_to):
            eprint(f"[toolchain] extracting to: {extract_to}")
            ensure_dir(extract_to)
            subprocess.run(["tar", "xzf", str(tmp_path), "-C", str(extract_to)], check=True)
        elif os.geteuid() == 0:
            eprint(f"[toolchain] extracting to: {extract_to}")
            ensure_dir(extract_to)
            subprocess.run(["tar", "xzf", str(tmp_path), "-C", str(extract_to)], check=True)
        else:
            if shutil.which("sudo") is None:
                raise RuntimeError(
                    f"no write permission to '{extract_to}', and sudo is not available"
                )
            eprint(f"[toolchain] '{extract_to}' requires sudo permission")
            run_sudo(["mkdir", "-p", str(extract_to)])
            run_sudo(["tar", "xzf", str(tmp_path), "-C", str(extract_to)])

    finally:
        try:
            tmp_path.unlink(missing_ok=True)
        except OSError:
            pass

    if not bin_path.is_dir():
        raise RuntimeError(
            f"toolchain '{tc_name}' extracted, but bin path not found: {bin_path}"
        )

    eprint(f"[toolchain] installed: {bin_path}")
    return bin_path


def handle_toolchains(args):
    parsed = parse_toolchains_args(args)
    if parsed["help"]:
        print(
            "Usage:\n"
            "  tbox toolchain --list [--config <ci_boards.json>]\n"
            "  tbox toolchain <name> [--config <ci_boards.json>]\n\n"
            "Examples:\n"
            "  tbox toolchain --list\n"
            "  tbox toolchain aarch64-musl\n"
        )
        return

    toolchains = load_toolchains(parsed["config"])

    if parsed["list_only"]:
        for name in sorted(toolchains.keys()):
            print(name)
        return

    name = parsed["name"]
    if name not in toolchains:
        names = ", ".join(sorted(toolchains.keys()))
        raise ValueError(f"unknown toolchain '{name}', available: {names}")

    bin_path = ensure_toolchain_installed(name, toolchains[name])
    export_cmd = f"export PATH={shlex.quote(str(bin_path))}:$PATH"
    print(f"[toolchain] 请执行以下命令设置工具链环境变量：{export_cmd}")


def copy_vscode_templates():
    if not VSCODE_TEMPLATE_DIR.is_dir():
        raise FileNotFoundError(f"vscode template directory not found: {VSCODE_TEMPLATE_DIR}")

    VSCODE_TARGET_DIR.mkdir(parents=True, exist_ok=True)

    copied = 0
    skipped = 0
    for src in sorted(VSCODE_TEMPLATE_DIR.rglob("*")):
        rel = src.relative_to(VSCODE_TEMPLATE_DIR)
        dst = VSCODE_TARGET_DIR / rel

        if src.is_dir():
            dst.mkdir(parents=True, exist_ok=True)
            continue

        if dst.exists():
            print(f"[vscode] skip existing: {dst}")
            skipped += 1
            continue

        dst.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(src, dst)
        print(f"[vscode] copied: {dst}")
        copied += 1

    print(f"[vscode] done, copied={copied}, skipped={skipped}")

def run_gen_presets(extra_args):
    board_dirs = [str(BOARD_DIR) + "/yaml"]
    board_dirs += find_ext_board_dirs()

    cmd = [
        sys.executable,
        GEN_PRESETS,
    ]

    if extra_args:
        # 用户显式传参：完全透传
        cmd += extra_args
    else:
        # 默认行为：schema + 所有 board_dirs
        cmd += [
            SCHEMA,
            *board_dirs,
        ]

    subprocess.run(cmd, check=True)


def print_completion(shell: str):
    if shell != "bash":
        print(f"[ERROR] unsupported shell for completion: {shell}", file=sys.stderr)
        print("supported shells: bash", file=sys.stderr)
        sys.exit(2)

    if not COMPLETION_SCRIPT.is_file():
        print(f"[ERROR] completion script not found: {COMPLETION_SCRIPT}", file=sys.stderr)
        sys.exit(2)

    print(COMPLETION_SCRIPT.read_text(encoding="utf-8"), end="")


def main():
    argv = sys.argv[1:]

    # ---------- tbox 自身 help ----------
    if argv and argv[0] in ("?", "-h", "--help"):
        print(
            "Usage:\n"
            "  tbox [gen_presets args]\n"
            "  tbox vscode\n"
            "  tbox completion [bash]\n"
            "  tbox toolchain --list [--config <ci_boards.json>]\n"
            "  tbox toolchain <name> [--config <ci_boards.json>]\n"
            "  tbox --ext [ext args]\n\n"
            "Examples:\n"
            "  tbox\n"
            "  tbox vscode\n"
            "  source <(./tbox completion bash)\n"
            "  tbox toolchain aarch64-musl\n"
            "  tbox -f qemu-a9.yaml\n"
            "  tbox --ext --list\n"
            "  tbox --ext --offline-export /tmp/boards-prj.tar.gz\n"
            "  tbox --ext --offline-import /tmp/boards-prj.tar.gz\n"
        )
        sys.exit(0)

    if argv and argv[0] == "completion":
        shell = argv[1] if len(argv) > 1 else "bash"
        if len(argv) > 2:
            print("[ERROR] 'completion' takes at most one argument", file=sys.stderr)
            usage()
            sys.exit(2)
        print_completion(shell)
        return

    if argv and argv[0] == "vscode":
        if len(argv) > 1:
            print("[ERROR] 'vscode' command does not accept extra arguments", file=sys.stderr)
            usage()
            sys.exit(2)
        copy_vscode_templates()
        return

    if argv and argv[0] == "toolchain":
        try:
            handle_toolchains(argv[1:])
        except (ValueError, FileNotFoundError, RuntimeError, json.JSONDecodeError) as e:
            print(f"[ERROR] {e}", file=sys.stderr)
            sys.exit(2)
        return


    # ext 模式：--ext 必须是第一个参数
    if argv and argv[0] == "--ext":
        ext_args = argv[1:]  # 后续参数原样透传

        run([
            sys.executable,
            EXT_SCRIPT,
            *ext_args
        ])
        return

    # 错误用法：--ext 出现在非第一个位置
    if "--ext" in argv:
        print("[ERROR] '--ext' must be the first argument", file=sys.stderr)
        usage()
        sys.exit(2)

    # 错误用法：未知子命令（避免误透传到 gen_presets）
    if argv and not argv[0].startswith("-"):
        print(f"[ERROR] unknown command: {argv[0]}", file=sys.stderr)
        usage()
        sys.exit(2)

    # ---------- normal 模式 ----------
    if argv:
        # 用户传参：透传（但不包括 help，因为已拦截）
        run_gen_presets(argv)
    else:
        # ⭐ 无参数：默认 schema + builtin + ext boards
        run_gen_presets([])

        run([
            sys.executable,
            KCFG_AUTO,
        ])


if __name__ == "__main__":
    try:
        main()
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)
