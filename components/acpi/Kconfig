config ACPI
    bool "Enable ACPI Support"
    default n if !ARCH_X86_64
    default y if ARCH_X86_64
    help
        Enable support for ACPI

config ACPI_DEBUG
    bool "Enable ACPI Debug"
    default n
    depends on ACPI
    help
        Enable support for ACPI Debug
